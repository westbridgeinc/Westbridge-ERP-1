# ──────────────────────────────────────────────────────────────────────────────
# Westbridge ERP Frontend — Production Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in real values before deploying.
# For Fly.io: use `fly secrets set KEY=VALUE` instead of a .env file.
# ──────────────────────────────────────────────────────────────────────────────

# ── Server-side only (not exposed to browser) ────────────────────────────────
NODE_ENV=production
BACKEND_URL=http://westbridge-api.internal:4000  # Fly.io private network

# ── Client-side (NEXT_PUBLIC_ prefix, sent to browser) ──────────────────────
NEXT_PUBLIC_API_URL=https://api.westbridge.app     # Public API URL for browser
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxx
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Sentry build-time (for source map upload) ───────────────────────────────
SENTRY_ORG=westbridge
SENTRY_PROJECT=westbridge-frontend
SENTRY_AUTH_TOKEN=sntrys_xxxxx
