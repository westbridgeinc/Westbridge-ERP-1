# ═══════════════════════════════════════════════════════════
# Westbridge Frontend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env.local and fill in values.

# ─── Required ─────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
BACKEND_URL=http://localhost:4000

# ─── Observability (optional in dev) ──────────────────────
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Caribbean Defaults ──────────────────────────────────
# These are baked into the codebase but documented here for clarity.
# DEFAULT_CURRENCY=GYD
# VAT_RATE=0.14
# NIS_EMPLOYER_RATE=0.088
# NIS_EMPLOYEE_RATE=0.056
# NIS_CEILING=280000
# PAYE_THRESHOLD=780000
